  .row-left { flex: 1; min-width: 0; }
  .row-right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }

  .row-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .ch-num {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ch-section {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--color-slate);
    opacity: 0.6;
  }

  .ch-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 0.4rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ch-title a { text-decoration: none; color: inherit; }
  .ch-title a:hover { text-decoration: underline; }

  .audience-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .audience-tag {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    background: var(--color-warm-gray);
    color: var(--color-slate);
    border: 1px solid var(--color-border);
  }

  .plans-badge {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background: #D1FAE5;
    color: #065F46;
    white-space: nowrap;
  }

  .contribute-btn {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-navy);
    text-decoration: none;
    white-space: nowrap;
