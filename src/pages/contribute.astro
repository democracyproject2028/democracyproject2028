  /* Chapter list */
  .chapter-list {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .chapter-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
