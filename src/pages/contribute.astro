  .dot-draft,     .status-dot.dot-draft     { background: var(--color-alert); }
  .dot-open,      .status-dot.dot-open      { background: var(--color-border); border: 1px solid #999; }

  /* Filter */
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .filter-btn {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
