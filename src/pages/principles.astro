---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const allPrinciples = await getCollection('principles');
const principles = allPrinciples.sort((a, b) => a.data.order - b.data.order);

const renderedPrinciples = await Promise.all(
  principles.map(async (principle) => {
    const { Content } = await render(principle);
    return { principle, Content };
  })
);
---

<BaseLayout
  title="The Seven Principles"
  description="The foundational values that animate the Democracy 2028 framework — seven principles that define what good, democratic, accountable governance looks like."
>
  <div class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Foundation</p>
      <h1>The Seven Principles</h1>
      <p class="hero-sub">
        Before policies come values. These seven principles define what Democracy 2028 stands for —
        the non-negotiable commitments that run through every chapter and every recommendation in the framework.
      </p>
    </div>
  </div>

  <div class="cards-section">
    <div class="max-container">
      <div class="cards-grid">
        {renderedPrinciples.map(({ principle }) => (
          <a href={`#principle-${principle.data.order}`} class="principle-card">
            <span class="card-icon">{principle.data.icon}</span>
            <div class="card-body">
              <p class="card-order">Principle {principle.data.order}</p>
              <h2 class="card-title">{principle.data.title}</h2>
              <p class="card-summary">{principle.data.summary}</p>
            </div>
            <span class="card-arrow" aria-hidden="true">↓</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="principles-list">
    <div class="max-container">
      {renderedPrinciples.map(({ principle, Content }, idx) => (
        <article
          id={`principle-${principle.data.order}`}
          class="principle-article"
        >
          <div class="article-header">
            <div class="article-header-meta">
              <span class="article-eyebrow">Principle {principle.data.order} of 7</span>
              <span class="article-icon" aria-hidden="true">{principle.data.icon}</span>
            </div>
            <h2 class="article-title">{principle.data.title}</h2>
            <p class="article-summary">{principle.data.summary}</p>
          </div>

          <div class="article-content prose-chapter">
            <Content />
          </div>

          {idx < renderedPrinciples.length - 1 && (
            <div class="article-nav">
              <a href={`#principle-${principle.data.order + 1}`} class="next-link">
                Next: Principle {principle.data.order + 1} &rarr;
              </a>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>

  <div class="cta-section">
    <div class="cta-inner">
      <h2 class="cta-title">Principles in Practice</h2>
      <p class="cta-body">
        These seven principles are not rhetorical. They are the evaluative lens applied to every
        recommendation in the 45-chapter framework. Read the framework, contribute to the project,
        or help refine these principles through the open-source process.
      </p>
      <div class="cta-actions">
        <a href="/framework" class="btn-primary">Read the Framework</a>
        <a href="/contribute" class="btn-secondary">Contribute</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .hero {
    background: var(--color-navy);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin: 0 0 1rem;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 1.25rem;
    line-height: 1.1;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    max-width: 55ch;
    margin: 0 auto;
  }

  /* ── Cards ─────────────────────────────────────────────────────────────── */
  .cards-section {
    background: var(--color-warm-gray);
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 1.5rem;
  }

  .max-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .principle-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    position: relative;
  }

  .principle-card:hover {
    border-color: var(--color-gold);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .card-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .card-body {
    flex: 1;
  }

  .card-order {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold);
    margin: 0 0 0.35rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }

  .card-summary {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-slate);
    margin: 0;
  }

  .card-arrow {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-gold);
    align-self: flex-end;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .principle-card:hover .card-arrow {
    opacity: 1;
  }

  /* ── Principle Articles ─────────────────────────────────────────────────── */
  .principles-list {
    padding: 4rem 1.5rem;
  }

  .principle-article {
    margin-bottom: 5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .principle-article:last-of-type {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .article-header {
    background: var(--color-warm-gray);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 2.5rem;
    margin-bottom: 2.5rem;
    max-width: var(--reading-width);
  }

  .article-header-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .article-eyebrow {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-gold);
  }

  .article-icon {
    font-size: 2.25rem;
    line-height: 1;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--color-navy);
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .article-summary {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-slate);
    margin: 0;
    font-style: italic;
  }

  /* Prose content */
  .article-content {
    max-width: var(--reading-width);
  }

  .article-content :global(p) {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #2D3748;
    margin: 0 0 1.4rem;
  }

  .article-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 2.5rem 0 0.875rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-border);
  }

  .article-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 2rem 0 0.6rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #2D3748;
    padding-left: 1.5rem;
    margin: 0 0 1.4rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-content :global(strong) {
    font-weight: 700;
    color: var(--color-navy);
  }

  .article-content :global(em) {
    font-style: italic;
  }

  /* Next link */
  .article-nav {
    margin-top: 2.5rem;
    max-width: var(--reading-width);
    text-align: right;
  }

  .next-link {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    border: 1px solid var(--color-gold);
    border-radius: 4px;
    padding: 0.4rem 0.9rem;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .next-link:hover {
    background: var(--color-gold);
    color: #fff;
  }

  /* ── CTA Section ────────────────────────────────────────────────────────── */
  .cta-section {
    background: var(--color-navy);
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 1rem;
  }

  .cta-body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 2rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 600;
    background: var(--color-gold);
    color: #fff;
    padding: 0.65rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .btn-primary:hover {
    opacity: 0.88;
  }

  .btn-secondary {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 600;
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    padding: 0.65rem 1.5rem;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.7);
    color: #fff;
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero {
      padding: 3rem 1.25rem 2.5rem;
    }

    .cards-section {
      padding: 2rem 1.25rem;
    }

    .principles-list {
      padding: 2.5rem 1.25rem;
    }

    .article-header {
      padding: 1.5rem;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
