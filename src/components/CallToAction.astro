---
interface Props {
  text: string;
  link: string;
  external?: boolean;
}

const { text, link, external = false } = Astro.props;
---

<div class="cta-block">
  <a
    href={link}
    class="cta-btn"
    {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  >
    {text}
    {external && <span aria-hidden="true"> ↗</span>}
  </a>
</div>

<style>
  .cta-block {
    text-align: center;
    margin: 2rem 0;
  }

  .cta-btn {
    display: inline-block;
    background: var(--color-navy);
    color: white;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }

  .cta-btn:hover {
    background: #253a63;
    transform: translateY(-1px);
  }
</style>
