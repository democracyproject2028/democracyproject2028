---
interface Props {
  title: string;
  description: string;
  authority: string;
}

const { title, description, authority } = Astro.props;
---

<div class="day-one-action">
  <div class="action-header">
    <span class="action-icon" aria-hidden="true">⚡</span>
    <strong class="action-title">{title}</strong>
  </div>
  <p class="action-desc">{description}</p>
  <p class="action-authority">
    <span class="authority-label">Authority:</span> {authority}
  </p>
</div>

<style>
  .day-one-action {
    border: 1px solid #FDE68A;
    background: #FFFBEB;
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 1rem 0;
  }

  .action-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .action-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .action-title {
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .action-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: #374151;
    margin: 0 0 0.6rem;
  }

  .action-authority {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-slate);
    margin: 0;
  }

  .authority-label {
    font-weight: 600;
  }
</style>
